{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "LuaJIT",
  "diagnostics.globals": ["vim", "MiniDeps", "Snacks"],
  "workspace.library": [
    "$VIMRUNTIME/lua",
    "${3rd}/luv/library"
